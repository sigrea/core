{
  "name": "sigrea",
  "version": "1.0.1",
  "sideEffects": false,
  "license": "MIT",
  "description": "The signal base reactive programming library.",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sigrea/core.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "unbuild",
    "prepack": "unbuild",
    "format": "biome check --write",
    "postinstall": "lefthook install",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "lefthook": "1.10.10",
    "tsx": "latest",
    "typescript": "5.7.3",
    "unbuild": "3.3.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "alien-signals": "^1.0.3",
    "es-toolkit": "^1.32.0"
  },
  "volta": {
    "node": "20.18.0",
    "pnpm": "10.4.1"
  }
}
